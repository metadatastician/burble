#             source files already declared MPL-2.0. Owner-confirmed alignment
#             to MPL-2.0 throughout (PR #114). LICENSE is now pure MPL-2.0.
# 2026-07-02: Truth-reconciliation pass (Phase 0 of the completion roadmap,
#             ADR-0007): completion-percentage removed in favor of
#             [feature-status]; CRG self-grade set to D (blocked on #100 —
#             the provisional C is withdrawn until the test gate is re-armed
#             and green); false labels corrected in code (Media.Engine
#             "Membrane" -> ex_webrtc session registry, Vext "blake3" ->
#             sha256, quick-join.html relabeled presence-lobby); dead
#             Multipath.send call removed from the RTP hot path; run.sh
#             launcher path, extension /recv rendering, and bridge-test
#             spawn paths fixed.

[crg]
grade = "D"
target-grade = "C"
blocked-on = "#100"
previous-grade = "C (provisional, 2026-04-21; withdrawn 2026-07-02)"
demoted-on = "2026-04-18"
demotion-reference = "docs/governance/CRG-AUDIT-2026-04-18.adoc"
notes = "Grade set to D 2026-07-02 per ADR-0007 receipts-first discipline: a disarmed CI test gate (continue-on-error: true, issue #100) cannot support grade C — the provisional C claimed 2026-04-21 predates that standard and is withdrawn until the gate is re-armed and green. Everything else needed for C is in place: web-client test suite wired (PR #104), CI/CD campaigns C001-C005 completed, SECURITY-DEPLOY.md + PROTOCOL.md published, license drift resolved (MPL-2.0 throughout, PR #114), READINESS.adoc + per-directory READMEs + elixir-ci.yml present. Re-grade to C with the green gated run URL as the receipt."

[ecosystem]
part-of = ["Burble Platform"]
depends-on = ["VeriSimDB", "proven", "Avow", "Vext", "Stapeln", "Axiom.jl", "Ephapax"]

# RSR-compliant .gitignore
# SPDX-License-Identifier: MPL-2.0
# Burble .gitignore - Comprehensive ignore patterns

# OS & Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Elixir / Erlang
server/_build/
server/deps/
server/cover/
server/*.ez
server/.elixir_ls/
# Server generated static (NOT the MVP index.html)
server/priv/static/assets/
server/priv/static/cache_manifest.json
server/priv/repo/*.lock

# ReScript
client/web/node_modules/
client/web/lib/
client/web/src/**/*.res.mjs
client/web/.cache/

# Deno
client/web/deno.lock
client/lib/deno.lock

# Client lib build artifacts
client/lib/node_modules/
client/lib/lib/

# Desktop (Tauri)
client/desktop/target/
client/desktop/src-tauri/target/

# Zig FFI build artifacts
ffi/zig/zig-out/
ffi/zig/zig-cache/
ffi/zig/.zig-cache/
ffi/zig/zig-out/
server/priv/burble_coprocessor.*
server/priv/libburble_coprocessor.*

# Idris2 build artifacts
src/abi/build/
**/*.ibc

# Build
dist/
*.beam

# Environment (NEVER commit secrets)
.env
.env.local
.env.production
erl_crash.dump

# Dependencies
/node_modules/
/vendor/
/deps/
/elixir_ls/

# Rust
# Cargo.lock  # Keep for binaries

# Elixir
/cover/
/doc/
*.ez
erl_crash.dump

# Julia
*.jl.cov
*.jl.mem
/Manifest.toml

# Python (SaltStack only)
__pycache__/
*.py[cod]
.venv/

# Ada/SPARK
*.ali
/obj/
/bin/

# Haskell
/.stack-work/
/dist-newstyle/

# Chapel
*.chpl.tmp.*

# Secrets
.env
.env.*
*.pem
*.key
secrets/

# Test/Coverage
/coverage/
htmlcov/

# Logs
*.log
/logs/

# Machine-readable locks
.machine_readable/.locks/

# Temp
/tmp/
*.tmp
*.bak

# asdf version manager — .tool-versions IS tracked in server/
# (pins Elixir/OTP combo). If you don't use asdf, the file is
# harmless to your toolchain. Out-of-repo .tool-versions stays ignored.
/.tool-versions

# Additional patterns for Burble
# Server-specific
server/priv/plts/
server/priv/gettext/
server/priv/repo/*.sqlite

# Client-specific
client/web/.parcel-cache/
client/web/.cache/

# Test artifacts
server/test/coverage/

# IDE/Editor specific
.vscode/
.idea/
*.swp
*.swo
*~
.direnv/

# Maintenance local artifacts
.maintenance-perms-state.tsv
docs/reports/maintenance/*.json

# Crash recovery artifacts
ai-cli-crash-capture/

# KDE metadata
.directory

# Sync artifacts
sync_report*.txt

# Hypatia scan cache (local-only)
.hypatia/

# Dependency management
mix.lock  # Typically not committed in Elixir projects

# Runtime/data files
server/priv/repo/

# Idris2 compiled output
src/build/

# wokelangiser generated i18n locale files (too large for GitHub)
generated/wokelangiser/i18n/
target/
node_modules/
_build/
deps/
.cache/
build/

# generated/* — produced by boj-server -mcp cartridges on push via *-regen.yml.
# DO NOT commit these. If missing locally, trigger regeneration:
#   curl -X POST http://boj-server.local:7700/cartridges/k9iser-mcp/invoke \
#     -d '{"repo": "hyperpolymath/<repo>", "tool": "k9_generate"}'
# Standards#93 / #89 sub-issue 1+2 must be wired before this line is safe.
generated/k9iser/
generated/tlaiser/
generated/wokelangiser/
generated/alloyiser/
generated/abi/

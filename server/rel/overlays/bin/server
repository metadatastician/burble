#
# Convenience wrapper: start Burble in foreground (for containers).
# Usage: bin/server
#
# Equivalent to: bin/burble start
# This script exists because Containerfile ENTRYPOINT expects bin/burble.

set -eu
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
exec "${SELF_DIR}/burble" start
